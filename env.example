# SearchArena runtime settings

# Model provider
API_BASE_URL=https://api.openai.com/v1
API_KEY=
HF_TOKEN=
MODEL_NAME=gpt-4o-mini

# Optional benchmark labeling
SEARCH_ENV_BENCHMARK=search_env
SEARCH_ENV_TASKS=sample_tech_instagram_001,sample_tech_whatsapp_001,sample_tech_facebook_acquisitions_001,sample_science_curie_001,sample_history_berlin_wall_001

# Environment connection
# Leave both blank to run the environment in-process.
LOCAL_IMAGE_NAME=
ENV_BASE_URL=

# Agent / inference settings
# NUM_EPISODES is currently kept for compatibility but the packaged runner
# executes one pass per task in SEARCH_ENV_TASKS.
NUM_EPISODES=1
SEARCH_TOP_K=5
READ_TOP_K=2
TEMPERATURE=0.2
MAX_COMPLETION_TOKENS=350
MAX_STEPS=

# Only passed through when using LOCAL_IMAGE_NAME
MAX_CONTEXT_TOKENS=

# Data generation settings
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
SERPER_API_KEY=
JINA_API_KEY=
CHROMA_API_KEY=
CHROMA_DATABASE=
BASETEN_MODEL_URL=
BASETEN_API_KEY=
USPTO_API_KEY=
SEARCH_API_KEY=
DATALAB_API_KEY=
